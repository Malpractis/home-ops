{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets#2.1.0",
    ":timezone(Australia/Melbourne)",
    // Org policy — LAST so it wins over the upstream :automergeBranch: forces
    // PR-based automerge. The org ruleset forbids direct pushes to the default
    // branch, so every automerge goes via a PR that Renovate auto-merges.
    "github>materia-ops/.github//renovate/default",
  ],
  packageRules: [
    // Auto-merge rules
    {
      description: "Auto-merge mise tools",
      matchManagers: [ "mise" ],
      matchUpdateTypes: [ "minor", "patch" ],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge trusted OCI digests",
      matchDatasources: [ "docker" ],
      matchUpdateTypes: [ "digest" ],
      matchPackageNames: [ "/home-operations/" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: "Auto-merge raidscope image (own semver releases via release-please)",
      matchDatasources: [ "docker" ],
      matchUpdateTypes: [ "digest", "minor", "patch" ],
      matchPackageNames: [ "/raidscope/" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: "Auto-merge wow-panel image (own semver releases via release-please)",
      matchDatasources: [ "docker" ],
      matchUpdateTypes: [ "digest", "minor", "patch" ],
      matchPackageNames: [ "/wow-panel/" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
    },
    {
      description: "AzerothCore server image — never auto-merge; human PR merge is the realm promotion gate (docs/wow-server: 01 §2, 10 §4)",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/azerothcore-wotlk-playerbots/" ],
      automerge: false,
    },
    {
      description: "AzerothCore MySQL image — never auto-merge; rolling the DB statefulset drops the worldserver's connection and loses unsaved realm progress. Run realm maintenance first.",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/library\\/mysql/" ],
      automerge: false,
      prBodyNotes: [
        "⚠️ **Realm maintenance required before merging.** This rolls the `azerothcore-db` statefulset under the live worldserver. First run `saveall` (or a full `server shutdown`) via the wow-panel admin page or SOAP, then merge; the worldserver reconnects/restarts on its own once MySQL is back.",
      ],
    },
    {
      description: "Auto-merge high-cadence OCI packages weekly",
      matchDatasources: [ "docker" ],
      matchUpdateTypes: [ "minor", "patch" ],
      matchPackageNames: [ "/kube-prometheus-stack/" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: false,
      schedule: [ "before 6am on Monday" ],
    },
    {
      description: "Auto-merge GitHub Actions",
      matchManagers: [ "github-actions" ],
      matchUpdateTypes: [ "minor", "patch", "digest" ],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge trusted GitHub Actions",
      matchManagers: [ "github-actions" ],
      matchPackageNames: [ "/^actions\\//", "/^renovatebot\\//" ],
      matchUpdateTypes: [ "minor", "patch", "digest" ],
      automerge: true,
      automergeType: "pr",
      minimumReleaseAge: "1 minute",
      ignoreTests: true,
    },
    {
      description: "Auto-merge Grafana dashboards",
      matchDatasources: [ "custom.grafana-dashboards" ],
      matchUpdateTypes: [ "major" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: true,
    },
    {
      description: "Auto-merge Renovate Presents",
      matchManagers: [ "renovate-config" ],
      matchUpdateTypes: [ "minor", "patch" ],
      automerge: true,
      automergeType: "pr",
      ignoreTests: true,
    },
    // Version constraint rules
    {
      description: "Proton Mail Bridge - only track v-prefixed release tags (repo mixes schemes)",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/videocurio\\/proton-mail-bridge/" ],
      allowedVersions: "/^v\\d/",
    },
    {
      description: "Hold MySQL at the 8.4 LTS line — AzerothCore does not support 9.x innovation releases",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/library\\/mysql/" ],
      allowedVersions: "<9.0.0",
    },
    // Grouping rules
    {
      description: "Actions Runner Controller Group",
      groupName: "actions-runner-controller",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/gha-runner-scale-set-controller/", "/gha-runner-scale-set/" ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/flux-operator/", "/flux-instance/" ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Kubernetes Group",
      groupName: "kubernetes",
      matchDatasources: [ "docker" ],
      matchPackageNames: [
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-proxy/",
        "/kube-scheduler/",
        "/kubelet/",
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 5,
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: [ "docker" ],
      matchPackageNames: [ "/rook-ceph/", "/rook-ceph-cluster/" ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Hold Rook-Ceph at v1.19.x",
      matchPackageNames: [ "/rook-ceph/", "/rook-ceph-cluster/" ],
      allowedVersions: "<1.20.0",
    },
    // Labeling rules
    {
      matchUpdateTypes: [ "major" ],
      addLabels: [ "type/major" ],
    },
    {
      matchUpdateTypes: [ "minor" ],
      addLabels: [ "type/minor" ],
    },
    {
      matchUpdateTypes: [ "patch" ],
      addLabels: [ "type/patch" ],
    },
    {
      matchUpdateTypes: [ "digest" ],
      addLabels: [ "type/digest" ],
    },
  ],
}
