---
apiVersion: v1
kind: Namespace
metadata:
  name: network
  annotations:
    kustomize.toolkit.fluxcd.io/prune: disabled
---
# bootstrap seed — ExternalSecret (certificates/import) takes over once ESO is running
apiVersion: v1
kind: Secret
metadata:
  name: materia-wtf-production-tls
  namespace: network
type: kubernetes.io/tls
data: {{ ENV['lets_encrypt_tls'] | safe }}
