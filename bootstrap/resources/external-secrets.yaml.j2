---
apiVersion: v1
kind: Namespace
metadata:
  name: security
  annotations:
    kustomize.toolkit.fluxcd.io/prune: disabled
---
apiVersion: v1
kind: Namespace
metadata:
  name: flux-system
  annotations:
    kustomize.toolkit.fluxcd.io/prune: disabled
---
apiVersion: v1
kind: Secret
metadata:
  name: bitwarden-access-token-secret
  namespace: security
stringData:
  # this can NOT end in a newline or it doesn't work
  token: {{ ENV['bitwarden_auth_token_rw'] }}
---
# needed by Flux to substitute ClusterSecretStore config before ESO is running
# no ExternalSecret manages this — circular dependency (ESO needs it to configure its own store)
apiVersion: v1
kind: Secret
metadata:
  name: bitwarden-config
  namespace: security
stringData:
  BITWARDEN_ORGANIZATION_ID: {{ ENV['bitwarden_org_id'] }}
  BITWARDEN_PROJECT_ID: {{ ENV['bitwarden_project_id'] }}
