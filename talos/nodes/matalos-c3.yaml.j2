---
machine:
  type: controlplane
  install:
    diskSelector:
      model: Samsung SSD 980 1TB
    # renovate: depName=ghcr.io/siderolabs/installer
    image: factory.talos.dev/installer/349fb830e325ac0ecac1e9c23f54fdc9f1e3bfaa8ced7f6b09ebeda4a431fffa:v1.13.0
    wipe: false
    grubUseUKICmdline: true
---
apiVersion: v1alpha1
kind: HostnameConfig
hostname: matalos-c3
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: ipmi
selector:
  match: link.driver == "e1000e"
---
apiVersion: v1alpha1
kind: LinkConfig
name: ipmi
up: true
addresses: []
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net0
selector:
  match: link.driver == "igc" && mac(link.permanent_addr) == "02:76:c6:01:2b:bd"
---
apiVersion: v1alpha1
kind: LinkAliasConfig
name: net1
selector:
  match: link.driver == "igc" && mac(link.permanent_addr) == "02:76:c6:01:2b:be"
---
apiVersion: v1alpha1
kind: BondConfig
name: bond0
links:
  - net0
  - net1
bondMode: 802.3ad
lacpRate: fast
xmitHashPolicy: layer3+4
miimon: 100
updelay: 200
downdelay: 200
mtu: 9000
---
apiVersion: v1alpha1
kind: DHCPv4Config
name: bond0
clientIdentifier: mac
