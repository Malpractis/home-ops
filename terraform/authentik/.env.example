# For local runs. In GHA this is set from secrets.OP_SERVICE_ACCOUNT_TOKEN.
# Create a service account at: 1Password → Settings → Developer → Service Accounts
# Grant it read access to the "kubernetes" vault.

export OP_SERVICE_ACCOUNT_TOKEN=
export AWS_ACCESS_KEY_ID=    # Garage terraform-state-key access key ID
export AWS_SECRET_ACCESS_KEY= # Garage terraform-state-key secret key
