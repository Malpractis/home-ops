# Loaded via /etc/mysql/conf.d/zz-homeops.cnf (after the image defaults).
[mysqld]
# 2 human players + a few hundred bots, and the DB idles 24/7 — a modest pool
# keeps steady-state memory well inside the 1Gi request / 2Gi limit.
innodb_buffer_pool_size = 512M
# mysqldump CronJobs are the recovery mechanism; binlogs would only eat the PVC.
skip_log_bin
# Pod IPs have no reverse DNS; don't stall connections on lookups.
skip_name_resolve
# AzerothCore schemas are utf8mb4/utf8mb4_general_ci.
character-set-server = utf8mb4
collation-server = utf8mb4_general_ci
# Saves several hundred MB on an instance nobody profiles.
performance_schema = OFF
